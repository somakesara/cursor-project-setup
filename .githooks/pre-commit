#!/usr/bin/env bash
set -euo pipefail

EXPECTED_EMAIL="you@example.com"

# --- Identity check ---
ACTUAL_EMAIL="$(git config user.email || true)"
if [ "$ACTUAL_EMAIL" != "$EXPECTED_EMAIL" ]; then
  echo "ERROR: git user.email is '$ACTUAL_EMAIL', expected '$EXPECTED_EMAIL'."
  echo "       Set it with: git config user.email \"$EXPECTED_EMAIL\""
  exit 1
fi

# --- Secret leak check ---
STAGED_DIFF="$(git diff --cached --unified=0)"

# Patterns to reject
SECRET_PATTERNS=(
  '-----BEGIN (RSA|EC|DSA|OPENSSH|PGP) PRIVATE KEY'
  'PRIVATE KEY-----'
  'AIza[0-9A-Za-z_-]{35}'
  'AKIA[0-9A-Z]{16}'
  'sk-[a-zA-Z0-9]{32,}'
  'ghp_[a-zA-Z0-9]{36}'
  'gho_[a-zA-Z0-9]{36}'
  'github_pat_[a-zA-Z0-9_]{82}'
  'xox[baprs]-[0-9a-zA-Z]{10,}'
  '[Aa][Pp][Ii][_-]?[Kk][Ee][Yy]\s*[:=]\s*["\x27]?[0-9a-zA-Z_\-]{20,}'
  '[Ss][Ee][Cc][Rr][Ee][Tt]\s*[:=]\s*["\x27]?[0-9a-zA-Z_\-]{20,}'
)

FOUND=0
for pattern in "${SECRET_PATTERNS[@]}"; do
  if echo "$STAGED_DIFF" | grep -qE "^\+.*${pattern}"; then
    echo "ERROR: Possible secret detected in staged diff (pattern: ${pattern})"
    FOUND=1
  fi
done

if [ "$FOUND" -ne 0 ]; then
  echo "       Review the diff with: git diff --cached"
  echo "       If this is a false positive, you can bypass with: git commit --no-verify"
  exit 1
fi

echo "pre-commit: identity and secret checks passed."
exit 0
