# Default: normalize line endings to LF on commit, check out as LF
* text=auto eol=lf

# Windows scripts: keep CRLF on Windows checkout
*.ps1 text eol=crlf
*.bat text eol=crlf
*.cmd text eol=crlf

# Shell scripts: always LF
*.sh text eol=lf

# True binary files: no line-ending conversion
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.gz binary
*.tar binary
*.tgz binary
*.7z binary
*.exe binary
*.dll binary
*.so binary
*.dylib binary
*.wasm binary
*.ttf binary
*.woff binary
*.woff2 binary
*.eot binary
